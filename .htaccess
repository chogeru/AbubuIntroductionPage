# ============================================================
# Apache Security Configuration (.htaccess)
# ============================================================
# レンタルサーバー (さくら・エックスサーバー等) や
# Apache ウェブサーバーでホスティングする場合に有効。
# ============================================================


# ── HTTPS 強制リダイレクト ────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]


# ── セキュリティヘッダー ─────────────────────────────────

# クリックジャッキング防止
Header always set X-Frame-Options "DENY"

# MIMEタイプスニッフィング防止
Header always set X-Content-Type-Options "nosniff"

# リファラー情報の制限
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# 不要なブラウザ機能を全て無効化
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"

# Content Security Policy
Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https://img.youtube.com; font-src 'self'; connect-src 'none'; object-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'"

# HSTS: 1年間 HTTPS を強制
# ※ HTTPS で運用している場合のみ有効にすること
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

# 同一オリジンポリシーの強化
Header always set Cross-Origin-Opener-Policy "same-origin"
Header always set Cross-Origin-Resource-Policy "same-origin"

# サーバー情報の隠蔽
ServerSignature Off
Header unset X-Powered-By
Header always unset Server


# ── ディレクトリ一覧の無効化 ─────────────────────────────
Options -Indexes


# ── 機密ファイルへのアクセス拒否 ─────────────────────────
<FilesMatch "\.(env|log|sh|sql|bak|config|json|lock|md|yml|yaml|git)$">
    Require all denied
</FilesMatch>

# .htaccess 自体へのアクセスも拒否
<Files ".htaccess">
    Require all denied
</Files>


# ── 古いブラウザのキャッシュ制御 ────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html             "access plus 1 hour"
    ExpiresByType text/css              "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png             "access plus 1 year"
    ExpiresByType image/jpeg            "access plus 1 year"
    ExpiresByType image/webp            "access plus 1 year"
    ExpiresByType image/svg+xml        "access plus 1 month"
</IfModule>
